# ╔══════════════════════════════════════════════════════════════╗
# ║  FatturaMVP - Configurazione Environment Variables           ║
# ║  Copia questo file in .env e riempi con i tuoi valori        ║
# ╚══════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────
# Database PostgreSQL
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://fattura:changeme@db:5432/fattura
POSTGRES_DB=fattura
POSTGRES_USER=fattura
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ──────────────────────────────────────────────
# Sicurezza
# ──────────────────────────────────────────────
SECRET_KEY=change_me_in_production_use_a_strong_random_key

# ──────────────────────────────────────────────
# Debug (true solo in sviluppo)
# ──────────────────────────────────────────────
DEBUG=false

# ──────────────────────────────────────────────
# SDI - Sistema Di Interscambio (Fatturazione Elettronica)
# ──────────────────────────────────────────────
OPENAPI_SDI_KEY=your_key_here

# ──────────────────────────────────────────────
# Brevo - Email marketing e transactional
# ──────────────────────────────────────────────
BREVO_API_KEY=your_key_here
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_login_here
BREVO_SMTP_PASSWORD=your_password_here

# ──────────────────────────────────────────────
# Telegram Bot
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# ──────────────────────────────────────────────
# Stripe - Pagamenti
# ──────────────────────────────────────────────
STRIPE_API_KEY=your_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# ──────────────────────────────────────────────
# Twilio - WhatsApp Business
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+39xxxxxxxxx

# ──────────────────────────────────────────────
# MiniMax - AI (già configurato nel progetto)
# ──────────────────────────────────────────────
MINIMAX_API_KEY=already_set

# ──────────────────────────────────────────────
# Porte dei servizi
# ──────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80
NGINX_SSL_PORT=443

# ──────────────────────────────────────────────
# URL di produzione (per email, webhook, etc.)
# ──────────────────────────────────────────────
APP_URL=https://tuo-dominio.it
FRONTEND_URL=https://tuo-dominio.it
BACKEND_URL=https://api.tuo-dominio.it
